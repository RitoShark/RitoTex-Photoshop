IDD_MAINDIALOG DIALOGEX 0, 0, 300, 224
STYLE DS_SETFONT | WS_POPUP
FONT 9, "Segoe UI", 400, 0, 0x0
BEGIN
    // NOTE: the custom title bar (top ~22px) is painted in WM_PAINT, and the
    // three dropdowns (compression / error-metric / mipmap) are created at
    // runtime in BuildCustomDropdowns() at pixel coordinates — they are NOT
    // declared here. Coordinates below are DLU; runtime dropdowns use pixels.

    // --- Compression ---
    LTEXT           "Compression Format",-1,12,30,150,9
    // dropdown drawn at runtime: pixel (22,52) 200x26
    LTEXT           "BC7: 8 bpp. Highest-quality color + alpha. Best overall choice.",IDC_COMPRESSION_HINT,22,84,266,18

    // --- Quality (BC1/BC3 only) ---
    LTEXT           "Quality (BC1 / BC3 only)",-1,12,112,150,9
    CONTROL         "Enable Dithering",IDC_DITHERING_CHECK,"Button",BS_OWNERDRAW | WS_TABSTOP,158,116,120,14
    LTEXT           "Error Metric",IDC_ERRORMETRIC_LABEL,22,138,50,12
    // error-metric dropdown drawn at runtime: pixel (78,132) 150x26

    // --- Mipmaps ---
    LTEXT           "Mip Generation",-1,12,172,60,12
    // mipmap dropdown drawn at runtime: pixel (110,176) 160x26

    // --- Action buttons (owner-drawn) ---
    PUSHBUTTON      "Preview",IDC_PREVIEW_BUTTON,12,194,72,22,BS_OWNERDRAW
    DEFPUSHBUTTON   "Export",IDOK,156,194,60,22,BS_OWNERDRAW
    PUSHBUTTON      "Cancel",IDCANCEL,220,194,60,22,BS_OWNERDRAW

    // Hidden controls kept for compatibility with existing code paths.
    COMBOBOX        IDC_PRESET_COMBO,0,0,0,0,CBS_DROPDOWNLIST | NOT WS_VISIBLE
    COMBOBOX        IDC_TEXTURETYPE_COMBO,0,0,0,0,CBS_DROPDOWNLIST | NOT WS_VISIBLE
    COMBOBOX        IDC_COMPRESSION_COMBO,0,0,0,0,CBS_DROPDOWNLIST | NOT WS_VISIBLE
    COMBOBOX        IDC_MIPMAP_COMBO,0,0,0,0,CBS_DROPDOWNLIST | NOT WS_VISIBLE
    COMBOBOX        IDC_ERRORMETRIC_COMBO,0,0,0,0,CBS_DROPDOWNLIST | NOT WS_VISIBLE
    CONTROL         "",IDC_CUBEMIPLEVEL_CHECK,"Button",BS_AUTOCHECKBOX | NOT WS_VISIBLE,0,0,0,0
    COMBOBOX        IDC_MIPLEVEL_COMBO,0,0,0,0,CBS_DROPDOWNLIST | NOT WS_VISIBLE
    CONTROL         "",IDC_NORMALIZE_CHECK,"Button",BS_AUTOCHECKBOX | NOT WS_VISIBLE,0,0,0,0
    CONTROL         "",IDC_FLIPX_CHECK,"Button",BS_AUTOCHECKBOX | NOT WS_VISIBLE,0,0,0,0
    CONTROL         "",IDC_FLIPY_CHECK,"Button",BS_AUTOCHECKBOX | NOT WS_VISIBLE,0,0,0,0
    PUSHBUTTON      "",IDC_PRESETSAVE_BUTTON,0,0,0,0,NOT WS_VISIBLE
    PUSHBUTTON      "",IDC_PRESETDELETE_BUTTON,0,0,0,0,NOT WS_VISIBLE
    PUSHBUTTON      "",IDC_COMPRESSION_HELP,0,0,0,0,NOT WS_VISIBLE
    PUSHBUTTON      "",IDC_TEXTURETYPE_HELP,0,0,0,0,NOT WS_VISIBLE
    PUSHBUTTON      "",IDC_PRECOMPRESS_HELP,0,0,0,0,NOT WS_VISIBLE
    PUSHBUTTON      "",IDC_MIPMAP_HELP,0,0,0,0,NOT WS_VISIBLE
    LTEXT           "",IDC_TEXTURETYPE_HINT,0,0,0,0,NOT WS_VISIBLE
    LTEXT           "",IDC_MIPMAPS_HINT,0,0,0,0,NOT WS_VISIBLE
END

IDD_ABOUT DIALOGEX 0, 0, 225, 63
STYLE DS_SETFONT | DS_MODALFRAME | DS_3DLOOK | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
